# Onfly API (new host — use https://api.onfly.com unless your tenant differs)
ONFLY_API_BASE_URL=https://api.onfly.com

# Local dev: MCP accepts either Authorization: Bearer … or this fallback (never commit .env)
ONFLY_DEV_ACCESS_TOKEN=

# Server
MCP_PORT=3000
MCP_HOST=127.0.0.1
# Max JSON body for POST /mcp (tools/call with base64). Default 18mb ≈ 10MiB attachment as base64. SDK ~100kb is too small.
# MCP_JSON_BODY_LIMIT=18mb

# Timeout for outbound Onfly API calls in ms (default 90s). Prevents silent hangs on slow uploads.
# ONFLY_API_TIMEOUT_MS=90000

# Dev: log each MCP request (method, tool name, and params — PII keys redacted). On Windows, set this if `npm run dev` does not pass env vars.
MCP_DEBUG=1

# If your HTTP client sends tools/call without Mcp-Session-Id, use stateless mode (no SSE GET). Default is stateful (Claude-style session).
# MCP_STATELESS=1
